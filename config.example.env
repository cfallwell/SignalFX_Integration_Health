# Splunk Observability realm, for example us0, us1, eu0, au0, jp0.
SFX_REALM=us0

# Token used to query the Observability API.
# It must be authorized to read integrations.
SFX_API_TOKEN=replace_me

# Token used to send custom metric datapoints.
# Use an ingest-capable organization access token.
SFX_INGEST_TOKEN=replace_me

# Optional overrides if your endpoint pattern differs.
# SFX_API_BASE=https://api.us0.observability.splunkcloud.com
# SFX_INGEST_BASE=https://ingest.us0.observability.splunkcloud.com

# Optional source dimension for custom metrics.
SFX_METRIC_SOURCE=synthetic-aws-integration-health
